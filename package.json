{
  "name": "rtodo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:app": "cross-env VITE_BASE_PATH=./ npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build:app && npx cap sync",
    "assets:generate": "npx @capacitor/assets generate --android --ios --iconBackgroundColor \"#E8F8F5\" --iconBackgroundColorDark \"#243038\" --splashBackgroundColor \"#E8F8F5\" --splashBackgroundColorDark \"#1e2830\"",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "android:debug": "npm run cap:sync && cd android && .\\gradlew.bat assembleDebug",
    "android:release": "npm run cap:sync && cd android && .\\gradlew.bat assembleRelease",
    "ios:release": "bash scripts/ios-release.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
