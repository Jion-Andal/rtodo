# Copy to keystore.properties and fill in (file is gitignored).
# Generate a keystore:
#   keytool -genkey -v -keystore rtodo-release.keystore -alias rtodo -keyalg RSA -keysize 2048 -validity 10000
storeFile=../rtodo-release.keystore
storePassword=your_store_password
keyAlias=rtodo
keyPassword=your_key_password
